services:
  cpa-control-center:
    image: ghcr.io/championcnlion/cpa-control-center-web:latest
    container_name: cpa-control-center
    restart: unless-stopped
    ports:
      - "127.0.0.1:8080:8080"
    environment:
      CPA_CONTROL_CENTER_LISTEN: ":8080"
      CPA_CONTROL_CENTER_DATA_DIR: /data
      CPA_CONTROL_CENTER_WEB_USERNAME: admin
      CPA_CONTROL_CENTER_WEB_PASSWORD: change-this-password
    volumes:
      - ./data:/data
